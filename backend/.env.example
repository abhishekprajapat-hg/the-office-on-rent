# Copy this file to backend/.env and fill real values locally or on the VPS.
# Never commit backend/.env or real secrets.

NODE_ENV=development
PORT=5000

# Preferred local mode: SSH tunnel to the VPS MongoDB.
# Example tunnel:
# ssh -L 27018:127.0.0.1:27017 root@YOUR_VPS_IP
# Example local tunneled URI:
# MONGO_URI=mongodb://office_app:STRONG_PASSWORD@127.0.0.1:27018/the_office_on_rent?authSource=the_office_on_rent
#
# Example production URI on the VPS:
# MONGO_URI=mongodb://office_app:STRONG_PASSWORD@127.0.0.1:27017/the_office_on_rent?authSource=the_office_on_rent
MONGO_URI=mongodb://office_app:STRONG_PASSWORD@127.0.0.1:27018/the_office_on_rent?authSource=the_office_on_rent

# Generate a strong secret with at least 32 random characters.
JWT_SECRET=replace-with-a-long-random-secret

# Comma-separated exact frontend origins allowed to call this backend.
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Use 1/true behind Nginx or another trusted reverse proxy in production.
TRUST_PROXY=false

MONGO_MAX_POOL_SIZE=25
MONGO_MIN_POOL_SIZE=1
MONGO_CONNECT_TIMEOUT_MS=10000
MONGO_SERVER_SELECTION_TIMEOUT_MS=10000

# Production/shared DB seed guard.
# Leave false by default. Set true only after taking a backup and confirming a
# seed/backfill/migration should write to the shared VPS database.
ALLOW_SHARED_DB_SEED=false

# Optional runtime tuning.
MONGO_AUTO_INDEX=false
MONGO_CONNECT_RETRY_DELAY_MS=3000
MONGO_CONNECT_MAX_RETRIES=0
LOG_LEVEL=info
METRICS_BEARER_TOKEN=replace-with-a-long-random-token
